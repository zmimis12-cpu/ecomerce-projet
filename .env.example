# =============================================================================
# GestionPro — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# =============================================================================

# ---------------------------
# Supabase (required)
# Found in: Supabase Dashboard → Project Settings → API
# ---------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ---------------------------
# Application
# ---------------------------
# Local development: http://localhost:3000
# Production: https://your-domain.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ---------------------------
# Google Sheets API (Step 7)
# Required for Google Sheets sync automation.
# ---------------------------
# Service account JSON — paste the full JSON as a single-line string
# Get from: Google Cloud Console → IAM → Service Accounts → Keys
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"

# Sheet IDs — from the Google Sheets URL:
# https://docs.google.com/spreadsheets/d/SHEET_ID/edit
GOOGLE_SHEET_ID_CONFIRMED=your-confirmed-orders-spreadsheet-id
GOOGLE_SHEET_ID_DELIVERED=your-delivered-paid-spreadsheet-id
GOOGLE_SHEET_ID_RETURNED=your-returned-orders-spreadsheet-id

# Sheet tab names (must match exactly the tab name in your spreadsheet)
GOOGLE_SHEET_NAME_CONFIRMED=Confirmed Orders
GOOGLE_SHEET_NAME_DELIVERED=Delivered Paid
GOOGLE_SHEET_NAME_RETURNED=Returns

# ---------------------------
# Cloudflare Turnstile (optional anti-bot)
# Get from: https://dash.cloudflare.com → Turnstile
# ---------------------------
TURNSTILE_SECRET_KEY=
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# ---------------------------
# Security
# A random secret used to salt IP hashes in rate limiting.
# Generate: openssl rand -hex 32
# ---------------------------
HASH_SALT=change-this-to-a-random-secret-string

# ---------------------------
# AI Content Generation (Step 10)
# ---------------------------
AI_PROVIDER=
OPENAI_API_KEY=
GEMINI_API_KEY=
NEXT_PUBLIC_AI_CONFIGURED=false
